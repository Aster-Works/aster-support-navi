# Aster Support Navi — 環境変数の例（.env.local にコピーして設定）
# 何も設定しなくても、型付き seed データで完全に動作します（MVP）。

# --- サイトURL（OGP / canonical / sitemap の絶対URL生成に使用） ---
# 本番は https://astersupport.com を設定（取得済ドメイン）。未設定なら http://localhost:3040。
NEXT_PUBLIC_SITE_URL=

# --- 制度データソース（任意・Slice A） ---
# DATA_SOURCE で読み取り元を切り替える（未設定・不正値は seed）:
#   seed     … 型付き seed（app/data）。ローカル既定。Supabase未設定でも完全に動く。
#   supabase … Supabase 制度DB（status=published のみ）。空なら空を返す。
#   hybrid   … Supabase published を優先し、未登録 slug を seed で補完。移行期に使う。
# 切替の前に: ① supabase/migrations/ を適用 → ② scripts/export-seed-to-sql.ts で
#   生成した SQL を service_role で投入 → ③ DATA_SOURCE=hybrid で検証 → ④ supabase。
DATA_SOURCE=seed

# Supabase（保存リスト同期 + 制度DB読み取り）。
# 公開ページは anon（publishable）キーのみで読む。service_role は使わない・置かない。
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# --- Google tag / アクセス解析 GA4（任意） ---
# Google 広告タグ（AW-18260421733）はコード側で固定。
# GA4 は未設定なら無効（カスタムイベント送信もしない）。
# 設定するとクエリ文字列を除いた path のみを送信する（診断入力・検索語は送らない）。
# 本番で有効化する際は、GA4 プロパティ側で「拡張計測(Enhanced Measurement)」をオフにすること
# （スクロール等の自動イベントが現在URLのクエリを拾うのを防ぐため）。
# NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# --- Google AdSense（任意・控えめな手動広告） ---
# publisher ID はコード側で ca-pub-1547495705896839 を固定。
# true + 広告ユニット slot が揃うまで広告スクリプトは読み込まない。
# Auto Ads は使わず、まずはガイド記事末尾の手動枠だけから始める。
# NEXT_PUBLIC_ADSENSE_ENABLED=false
# NEXT_PUBLIC_ADSENSE_GUIDE_SLOT=

# --- 期限リマインド配信（任意・Slice D 続き） ---
# 下記がすべて揃うまで配信は安全に no-op（UI も NEXT_PUBLIC_REMINDERS_ENABLED で隠れる）。
# 揃えたら Vercel Cron（vercel.json で日次設定済）が /api/cron/send-reminders を叩いて送信する。
#   RESEND_API_KEY        … Resend の API キー（送信）
#   REMINDER_FROM_EMAIL   … 送信元（Resend で検証済みドメインのアドレス。例 noreply@astersupport.com）
#   SUPABASE_SERVICE_ROLE_KEY … reminders/ユーザーemail を RLS バイパスで読む（server-only 秘密・絶対に公開しない）
#   CRON_SECRET           … Vercel Cron の認証（設定すると Vercel が Bearer で送る。無認証送信を防ぐ）
#   NEXT_PUBLIC_REMINDERS_ENABLED=true … リマインド設定UIを表示（送信基盤を整えてから true に）
# RESEND_API_KEY=
# REMINDER_FROM_EMAIL=
# SUPABASE_SERVICE_ROLE_KEY=
# CRON_SECRET=
# NEXT_PUBLIC_REMINDERS_ENABLED=true
