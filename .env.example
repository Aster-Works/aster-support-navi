# Aster Support Navi — 環境変数の例（.env.local にコピーして設定）
# 制度データの正式な source of truth は Supabase DB です。

# --- サイトURL（OGP / canonical / sitemap の絶対URL生成に使用） ---
# 本番は https://astersupport.com を設定（取得済ドメイン）。未設定なら http://localhost:3040。
NEXT_PUBLIC_SITE_URL=

# --- 制度データソース ---
# DATA_SOURCE で読み取り元を切り替える（未設定・不正値は supabase）:
#   supabase … Supabase 制度DB（既定・本番唯一の正式データソース）。
#   seed     … 型付き seed（app/data）。緊急退避・ローカル初期データ確認のみ。
#   hybrid   … Supabase published を優先し、未登録 slug を seed で補完。移行検証専用。
#
# 新規制度追加・更新は app/data/programs.ts へ直接追記せず、管理画面の CSV 取込またはDB運用で行う。
DATA_SOURCE=supabase

# Supabase（保存リスト同期 + 制度DB読み取り）。
# 公開ページは anon（publishable）キーのみで読む。service_role は使わない・置かない。
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# --- Google tag / アクセス解析 GA4（任意） ---
# Google 広告タグ（AW-18260421733）はコード側で固定。
# GA4 は未設定なら無効（カスタムイベント送信もしない）。
# 設定するとクエリ文字列を除いた path のみを送信する（診断入力・検索語は送らない）。
# 本番で有効化する際は、GA4 プロパティ側で「拡張計測(Enhanced Measurement)」をオフにすること
# （スクロール等の自動イベントが現在URLのクエリを拾うのを防ぐため）。
# NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# --- Google AdSense（任意・控えめな手動広告） ---
# publisher ID はコード側で ca-pub-1547495705896839 を固定。
# true + 広告ユニット slot が揃うまで広告スクリプトは読み込まない。
# Auto Ads は使わず、まずはガイド記事末尾の手動枠だけから始める。
# NEXT_PUBLIC_ADSENSE_ENABLED=false
# NEXT_PUBLIC_ADSENSE_GUIDE_SLOT=

# --- Pro 決済（Stripe Payment Link・任意） ---
# 各有料プランの「申し込む」CTA が遷移する Stripe Payment Link の URL。
# 未設定なら CTA は問い合わせ（/pro#contact）へ安全にフォールバックする（クリックは stripe_click で計測）。
# Stripe ダッシュボードで「月額サブスク」の Payment Link を作成し、その https://buy.stripe.com/... を貼る。
# NEXT_PUBLIC_* はビルド時に静的置換されるため、設定・変更後は再デプロイが必要。
# NEXT_PUBLIC_STRIPE_LINK_PERSONAL=
# NEXT_PUBLIC_STRIPE_LINK_PRO=
# NEXT_PUBLIC_STRIPE_LINK_TEAM=

# --- 期限リマインド配信（任意・Slice D 続き） ---
# 下記がすべて揃うまで配信は安全に no-op（UI も NEXT_PUBLIC_REMINDERS_ENABLED で隠れる）。
# 揃えたら Vercel Cron（vercel.json で日次設定済）が /api/cron/send-reminders を叩いて送信する。
#   RESEND_API_KEY        … Resend の API キー（送信）
#   REMINDER_FROM_EMAIL   … 送信元（Resend で検証済みドメインのアドレス。例 noreply@astersupport.com）
#   SUPABASE_SERVICE_ROLE_KEY … reminders/ユーザーemail を RLS バイパスで読む（server-only 秘密・絶対に公開しない）
#   CRON_SECRET           … Vercel Cron の認証（設定すると Vercel が Bearer で送る。無認証送信を防ぐ）
#   NEXT_PUBLIC_REMINDERS_ENABLED=true … リマインド設定UIを表示（送信基盤を整えてから true に）
# RESEND_API_KEY=
# REMINDER_FROM_EMAIL=
# SUPABASE_SERVICE_ROLE_KEY=
# CRON_SECRET=
# NEXT_PUBLIC_REMINDERS_ENABLED=true

# --- 出典自動巡回（任意・Slice F 続き） ---
# Vercel Cron が /api/cron/check-sources を日次で叩き、support_sources の公式URLを少量ずつ取得します。
# 初回取得は fetched_content_hash のbaseline作成だけを行い、2回目以降に差分/取得失敗があれば
# review_queue_items へ積みます。制度本文・公開ステータスは自動変更しません。
# 必須:
#   SUPABASE_SERVICE_ROLE_KEY … support_sources/review_queue_items をRLSバイパスで更新（server-only 秘密）
#   CRON_SECRET               … Vercel Cron の Authorization 検証
# 任意:
#   SOURCE_CHECK_LIMIT        … 1回の最大巡回件数（既定15、上限50）
# SOURCE_CHECK_LIMIT=15

# --- 発見クローラ（任意・Slice G） ---
# Vercel Cron が /api/cron/crawl-support-sources を日次（03:00 JST）で叩き、自治体公式サイトを
# 少量ずつ巡回します。変更があったページだけ AI で支援制度候補を抽出し、support_program_candidates へ
# 積みます。公開 support_programs へは管理画面（/admin/crawler/review）で承認したものだけ反映されます。
# 安全側の既定として crawler_settings.crawler_enabled=false で出荷しています。
# 有効化は /admin/crawler の「クローラ全体」スイッチ、または crawler_settings を直接更新します。
# 必須:
#   SUPABASE_SERVICE_ROLE_KEY … クロール結果をRLSバイパスで書く（server-only 秘密・check-sources と共用）
#   CRON_SECRET               … Vercel Cron の Authorization 検証（check-sources と共用）
# AI抽出を使う場合（未設定ならクロール・変更検知のみ動作し、AI抽出は安全に no-op）:
#   ANTHROPIC_API_KEY         … Claude Haiku 4.5 で構造化抽出（server-only 秘密）
# ANTHROPIC_API_KEY=
