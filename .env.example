# Aster Support Navi — 環境変数の例（.env.local にコピーして設定）
# 何も設定しなくても、型付き seed データで完全に動作します（MVP）。

# --- サイトURL（OGP / canonical / sitemap の絶対URL生成に使用） ---
# 本番は https://astersupportnavi.jp を設定（事業構想のドメイン決定）。未設定なら http://localhost:3040。
NEXT_PUBLIC_SITE_URL=

# --- 制度データソース（任意・Phase 3） ---
# 未設定なら型付き seed（app/data）から読み込む。
# Supabase プロジェクトを用意し、supabase/migrations/ を適用してから設定する。
# 公開ページは anon（publishable）キーのみで読む。service_role は使わない・置かない。
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# --- 匿名計測（任意） ---
# 未設定なら計測は完全オフ。
# NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# --- メール登録 / 通知（任意・Phase 2以降） ---
# RESEND_API_KEY=
